{
  "name": "gameswap",
  "version": "2.0.0",
  "description": "GameSwap - Plateforme d'échange de jeux vidéo (BTS SIO SLAM)",
  "main": "backend/app.js",
  "scripts": {
    "start": "node backend/app.js",
    "dev:back": "nodemon backend/app.js",
    "dev:front": "cd frontend && npm run dev",
